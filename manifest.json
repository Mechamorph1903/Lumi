{
  "manifest_version": 3,
  "name": "Lumi",
  "version": "1.0",
  "description": "Lumi lights up what you're reading. No matter how dense the page, how complex the language, or how overwhelming the content — Lumi shines a light on what actually matters and speaks it to you in plain human language.",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

  "permissions": [
    "activeTab",        
    "scripting",        
    "storage",
    "tabs"          
  ],

  "host_permissions": [
    "https://api.anthropic.com/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "accessai@humane-glmg",
      "strict_min_version": "109.0"
    }
  },
   "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
  